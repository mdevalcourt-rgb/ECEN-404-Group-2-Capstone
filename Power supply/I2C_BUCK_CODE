#include <Wire.h>

#define MIC_ADDR 0x50
#define I2C_SDA 21
#define I2C_SCL 22

void setup() {
  Wire.begin(I2C_SDA, I2C_SCL);
  Serial.begin(115200);
  while (!Serial);

  Serial.println("\n--- MIC24045 RAW CALIBRATION MODE ---");
  Serial.println("Enter a Decimal value (0-250) or Hex (e.g., 0xFA)");

  // Ensure we are in High Range (Bits [7:6] = 10)
  Wire.beginTransmission(MIC_ADDR);
  Wire.write(0x01); // REG_SETTINGS1
  Wire.write(0x80); 
  Wire.endTransmission();
}

void loop() {
  if (Serial.available() > 0) {
    String input = Serial.readStringUntil('\n');
    input.trim();

    long rawValue;
    
    // Check if input is Hex (0x..) or Decimal
    if (input.startsWith("0x") || input.startsWith("0X")) {
      rawValue = strtol(input.c_str(), NULL, 16);
    } else {
      rawValue = input.toInt();
    }

    // Safety Cap at 0xFA (250) as per your testing
    if (rawValue >= 0 && rawValue <= 250) {
      uint8_t vcode = (uint8_t)rawValue;
      
      Wire.beginTransmission(MIC_ADDR);
      Wire.write(0x03); // VOUT Register
      Wire.write(vcode);
      
      if (Wire.endTransmission() == 0) {
        Serial.print("SUCCESS: Sent Code 0x");
        Serial.print(vcode, HEX);
        Serial.print(" (Dec: ");
        Serial.print(vcode);
        Serial.println(")");
      } else {
        Serial.println("ERROR: I2C Communication Failed.");
      }
    } else {
      Serial.println("OUT OF RANGE: Please enter 0 to 250 (0xFA)");
    }
  }
}
